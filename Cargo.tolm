[package]
name = "investment-wallet"
version = "0.1.0"
edition = "2021"

[dependencies]
axum = "0.7"
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
sqlx = { version = "0.7", features = ["runtime-tokio-rustls", "postgres", "macros"] }
dotenvy = "0.15"
jsonwebtoken = "9"
bcrypt = "0.15"
askama = "0.12"
tower-http = { version = "0.5", features = ["cors"] }
